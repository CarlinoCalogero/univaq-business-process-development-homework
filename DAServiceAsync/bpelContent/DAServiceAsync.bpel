<?xml version="1.0" encoding="UTF-8"?>
<bpel:process exitOnStandardFault="yes" name="DAServiceAsync.bpel"
	targetNamespace="http://daserviceasync.localhost/"
	xmlns:bpel="http://docs.oasis-open.org/wsbpel/2.0/process/executable"
	xmlns:ns="http://daserviceasync.localhost/Artifacts"
	xmlns:ns0="http://daserviceasync.localhost/" 
	xmlns:di="http://daservice.bpd.disim.univaq.it/"
	xmlns:bt="http://businesstravel.bpd.disim.univaq.it/" 
	xmlns:tns="http://daserviceasync.localhost/">

	<bpel:import importType="http://schemas.xmlsoap.org/wsdl/"
		location="daserviceasync.wsdl" namespace="http://daserviceasync.localhost/" />
	<bpel:import importType="http://schemas.xmlsoap.org/wsdl/"
		location="DAServiceAsyncArtifacts.wsdl" namespace="http://daserviceasync.localhost/Artifacts" />
	<bpel:import importType="http://schemas.xmlsoap.org/wsdl/"
		location="dainterface.wsdl" namespace="http://daservice.bpd.disim.univaq.it/" />
	<bpel:import importType="http://schemas.xmlsoap.org/wsdl/"
		location="businesstravel.wsdl" namespace="http://businesstravel.bpd.disim.univaq.it/" />

	<bpel:partnerLinks>
		<bpel:partnerLink myRole="DAServiceAsyncRole" name="clientAsyncPartner"
			partnerLinkType="ns:DAServiceAsyncPLT" partnerRole="BusinessTravelRole" />

		<bpel:partnerLink name="daServicePartner"
			partnerLinkType="ns:DAServicePLT" partnerRole="DAServiceRole" />
	</bpel:partnerLinks>

	<bpel:variables>
		<bpel:variable messageType="tns:flightTicket" name="flightTicketRequest" />
		<bpel:variable messageType="di:flightTicket" name="diflightTicketRequest" />
		<bpel:variable messageType="di:flightTicketResponse" name="diflightTicketResponse" />
		<bpel:variable messageType="bt:FlightTicketCallback" name="FlightTicketCallbackRequest" />
	</bpel:variables>

	<bpel:sequence name="MainSequence">
		<bpel:receive createInstance="yes" name="ReceiveFlightTicket"
			partnerLink="clientAsyncPartner" operation="flightTicket" portType="ns0:DAServiceAsync"
			variable="flightTicketRequest" />

		<bpel:assign>
			

			
            <bpel:copy>
                <bpel:from><bpel:literal><tns:flightTicket xmlns:tns="http://daservice.bpd.disim.univaq.it/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <arg0>
    <desiredDepartureDate>2001-12-31T12:00:00</desiredDepartureDate>
    <desiredReturnDate>2001-12-31T12:00:00</desiredReturnDate>
    <destinationTo>destinationTo</destinationTo>
    <originFrom>originFrom</originFrom>
  </arg0>
  <arg1>
    <travelclasstype>ECONOMY</travelclasstype>
  </arg1>
</tns:flightTicket>
</bpel:literal></bpel:from>
                <bpel:to variable="diflightTicketRequest" part="parameters"></bpel:to>
            </bpel:copy>
            <bpel:copy>
                <bpel:from part="parameters" variable="flightTicketRequest"></bpel:from>
                <bpel:to part="parameters" variable="diflightTicketRequest"></bpel:to>
            </bpel:copy>
        </bpel:assign>

		<bpel:invoke partnerLink="daServicePartner" operation="flightTicket"
			portType="di:DAInterface" inputVariable="diflightTicketRequest"
			outputVariable="diflightTicketResponse" />

		<bpel:assign>
			

			
            
            
            <bpel:copy>
                <bpel:from><bpel:literal><tns:FlightTicketCallback xmlns:tns="http://businesstravel.bpd.disim.univaq.it/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <return>
    <approved>true</approved>
    <departureDate>2001-12-31T12:00:00</departureDate>
    <flightNo>flightNo</flightNo>
    <price>0.0</price>
    <returnDate>2001-12-31T12:00:00</returnDate>
    <travelClass>
      <travelclasstype>ECONOMY</travelclasstype>
    </travelClass>
  </return>
</tns:FlightTicketCallback>
</bpel:literal></bpel:from>
                <bpel:to variable="FlightTicketCallbackRequest" part="parameters"></bpel:to>
            </bpel:copy>
            <bpel:copy>
                <bpel:from part="parameters" variable="diflightTicketResponse"></bpel:from>
                <bpel:to part="parameters" variable="FlightTicketCallbackRequest"></bpel:to>
            </bpel:copy>
        </bpel:assign>

		<bpel:invoke partnerLink="clientAsyncPartner" operation="FlightTicketCallback"
			portType="bt:BusinessTravel" inputVariable="FlightTicketCallbackRequest"/>
	</bpel:sequence>
</bpel:process>
